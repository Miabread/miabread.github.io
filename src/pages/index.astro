---
import 'normalize.css';
import Cloud from './cloud.astro';
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>miabread.github.io</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Fira+Sans&display=swap" rel="stylesheet" />
    </head>
    <body>
        <style>
            html,
            body {
                font-family: 'Fira Sans', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;

                margin: 0;
                padding: 0;
                width: 100%;
                height: 100dvh;
                overflow-x: hidden;
                position: relative;

                background: linear-gradient(165deg, #527785 0%, #527785 100%);
            }

            .glass {
                background-color: rgba(0, 0, 0, 0.3);
                backdrop-filter: blur(10px);
                border-radius: 1rem;
                padding: 1rem;
                border: 1px solid rgba(0, 0, 0, 0.1);
                box-shadow: 0px 4px 30px rgba(0, 0, 0, 0.1);
                color: white;
            }

            .main {
                margin: 2rem;
            }
        </style>
        <Cloud top={-20} left={-20} seed={123} />
        <Cloud top={10} left={20} seed={4567} />

        <div class="glass main">
